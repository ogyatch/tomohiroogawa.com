---
import worksData from '../../data/works.json';

export async function getStaticPaths() {
  return worksData.map((item) => {
    const index = worksData.findIndex(d => d.id === item.id);
    const prevItem = index > 0 ? worksData[index - 1] : null;
    const nextItem = index < worksData.length - 1 ? worksData[index + 1] : null;
    return {
      params: { id: item.id },
      props: { item, prevItem, nextItem },
    };
  });
}

const { item, prevItem, nextItem } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{item.title} | Tomohiro Ogawa</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400&family=Noto+Serif+JP:wght@200;300&display=swap" rel="stylesheet">

    <style>
      * { box-sizing: border-box; }
      html { scrollbar-gutter: stable; }

      body {
        font-family: "IBM Plex Mono", monospace;
        background-color: #fff;
        color: #111;
        margin: 0;
        height: 100dvh;
        overflow: hidden;
      }

      .inspection-container {
        display: grid;
        grid-template-rows: minmax(0, 1fr) auto;
        height: 100%;
        padding: 3rem;
        gap: 2rem;
        width: 100%;
      }

      .stage {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .artwork {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        cursor: zoom-out;
      }

      .instrument-panel {
        display: grid;
        grid-template-columns: 1fr 240px;
        gap: 2rem;
        width: 100%;
        align-items: start;
        max-height: 30vh;
        overflow-y: auto;
      }

      .panel-info {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      h1 {
        font-family: "Noto Serif JP", serif;
        font-weight: 300;
        font-size: 0.95rem;
        margin: 0;
        letter-spacing: 0.03em;
        line-height: 1.4;
      }

      .note {
        font-size: 0.72rem;
        color: #666;
        line-height: 1.7;
        margin: 0;
        max-width: 600px;
      }

      .panel-system {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        text-align: right;
      }

      .meta-data {
        font-size: 0.7rem;
        color: #999;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      .controls {
        font-size: 0.8rem;
        display: flex;
        justify-content: flex-end;
        gap: 1.5rem;
        margin-top: 0.5rem;
      }

      .control-link {
        text-decoration: none;
        color: #111;
        transition: opacity 0.2s;
      }
      .control-link:hover { opacity: 0.5; }

      .disabled {
        color: #e0e0e0;
        pointer-events: none;
      }

      .back-link {
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        color: #bbb;
        text-decoration: none;
        text-transform: uppercase;
        transition: color 0.2s;
      }
      .back-link:hover { color: #111; }

      @media (max-width: 768px) {
        .inspection-container { padding: 1.5rem; gap: 1rem; }
        .instrument-panel {
          grid-template-columns: 1fr;
          gap: 1.5rem;
          max-height: 40vh;
        }
        .panel-system {
          text-align: left;
          flex-direction: row;
          justify-content: space-between;
          align-items: flex-end;
        }
        .meta-data { text-align: left; }
      }
    </style>
  </head>
  <body>
    <div class="inspection-container">

      <div class="stage">
        <a href="/works" aria-label="Back to works">
          <img src={item.image} alt={item.title} class="artwork" />
        </a>
      </div>

      <footer class="instrument-panel">
        <div class="panel-info">
          <h1>{item.title}</h1>
          <p class="note">{item.note}</p>
        </div>

        <div class="panel-system">
          <div class="meta-data">
            <span>{item.date}</span>
            <span>{item.source}</span>
          </div>
          <nav class="controls">
            {prevItem ? (
              <a href={`/works/${prevItem.id}`} class="control-link">&larr; {prevItem.id}</a>
            ) : (
              <span class="control-link disabled">&larr; ---</span>
            )}
            <a href="/works" class="back-link">Works</a>
            {nextItem ? (
              <a href={`/works/${nextItem.id}`} class="control-link">{nextItem.id} &rarr;</a>
            ) : (
              <span class="control-link disabled">--- &rarr;</span>
            )}
          </nav>
        </div>
      </footer>

    </div>
  </body>
</html>
