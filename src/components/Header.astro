---
const { activeNav = "works" } = Astro.props;
---
<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    margin-left: -2rem;
    margin-right: -2rem;
    padding: 2.5rem 2rem 2.5rem;
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .inner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .site-identity {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.625rem;
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: #111;
    transition: opacity 0.2s;
  }
  .site-identity:hover { opacity: 0.5; }

  nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.625rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: #bbb;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #111; }
  .nav-link.active { color: #111; }
</style>

<header>
  <div class="inner">
    <a href="/" class="site-identity">Tomohiro Ogawa</a>
    <nav>
      <a href="/" class={`nav-link ${activeNav === 'works' ? 'active' : ''}`}>Works</a>
      <a href="/about" class={`nav-link ${activeNav === 'about' ? 'active' : ''}`}>About</a>
    </nav>
  </div>
</header>
